{
  "name": "email-automation",
  "version": "1.0.0",
  "description": "Local Gmail email automation desktop app",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k --names \"VITE,ELECTRON\" -c \"cyan,yellow\" \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "package": "vite build && electron-builder",
    "electron": "electron ."
  },
  "dependencies": {
    "googleapis": "^144.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "lucide-react": "^0.454.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.14",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.emailautomation.app",
    "productName": "Email Automation",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "extraResources": [
      {
        "from": "storage",
        "to": "storage"
      }
    ]
  }
}
